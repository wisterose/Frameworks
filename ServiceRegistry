local CollectionService = game:GetService("CollectionService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StudioSettings = require(ReplicatedStorage.StudioSettings)

local ServerStorage = game:GetService("ServerStorage")
local RunService = game:GetService("RunService")

local Loader = require(ReplicatedStorage.Packages.Loader)

local ModuleUtils = require(ReplicatedStorage.Utility.ModuleUtils)
local Logger = ModuleUtils.Logger.new(StudioSettings.DebugPrefix, StudioSettings.WithBrackets)

local ServiceRegistry = {}
ServiceRegistry.__index = ServiceRegistry

local ServerScriptsRegistered = false
local ClientScriptsRegistered = false

local LoadedClientModules = {} :: { [string]: { Instance: Instance, Env: "Server" | "Client" | "Shared" , Loaded: boolean} }
local LoadedServerModules = {} :: { [string]: { Instance: Instance, Env: "Server" | "Client" | "Shared" , Loaded: boolean} }

local ServicesParent = (RunService:IsServer() and ServerStorage.Services) or nil -- Change if needed

local function GetLoadedModules(t)
	local loaded = {}
	for name, info in t do
		if info.Loaded then
			loaded[name] = info.Module
		end
	end
	return loaded
end

function ServiceRegistry:Await(name: string, timeout: number?)
	local startTime = os.clock()
	local limit = timeout or 5

	while not (LoadedServerModules[name] or LoadedClientModules[name]) do
		if os.clock() - startTime > limit then
			Logger:warn("ModuleRegistry:Await() timed out for: " .. name)
			return nil
		end
		task.wait()
	end

	return self:Require(name)
end

function ServiceRegistry:RegisterServerScripts()
	if not RunService:IsServer() then Logger:warn("Cannot register server modules from client!") return end
	if ServerScriptsRegistered then Logger:warn("Server scripts already registered!") return end

	for _, module in CollectionService:GetTagged("Server") do
		module.Parent = ServicesParent

		local success, LoadedModule = pcall(function()
			return Loader.LoadModule(module, Loader.MatchesName("Server$"))
		end)

		if success then
			LoadedServerModules[module.Name] = {
				Module = LoadedModule,
				Env = "Server",
				Loaded = success
			}
		else
			Logger:warn("Failed to load module " .. module.Name .. ": " .. tostring(LoadedModule))
			LoadedServerModules[module.Name] = {Module = nil, Env = "Server", Loaded = false}
		end
	end

	Loader.SpawnAll(GetLoadedModules(LoadedServerModules), "Initialize")

	ServerScriptsRegistered = true

	local loadedmodulenames, notloadedmodulenames = {}, {}
	for name, t in LoadedServerModules do
		if t.Loaded then table.insert(loadedmodulenames, name)
		else table.insert(notloadedmodulenames, name) end
	end

	Logger:print("Loaded Server Modules: " .. table.concat(loadedmodulenames, ", "))
	if #notloadedmodulenames > 0 then
		Logger:print("Not Loaded Server Modules: " .. table.concat(notloadedmodulenames, ", "))
	end
end

function ServiceRegistry:RegisterClientScripts()
	if not RunService:IsClient() then Logger:warn("Cannot register client modules from server!") return end
	if ClientScriptsRegistered then Logger:warn("Client scripts already registered!") return end

	task.spawn(function()
		for _, module in CollectionService:GetTagged("Client") do
			local success, LoadedModule = pcall(function()
				return Loader.LoadModule(module, Loader.MatchesName("Client$"))
			end)

			if success then
				LoadedClientModules[module.Name] = {
					Module = LoadedModule,
					Env = "Client",
					Loaded = success
				}
			else
				Logger:warn("Failed to load module " .. module.Name .. ": " .. tostring(LoadedModule))
				LoadedClientModules[module.Name] = {Module = nil, Env = "Client", Loaded = false}
			end
		end

		Loader.SpawnAll(GetLoadedModules(LoadedClientModules), "Initialize")
		
		ClientScriptsRegistered = true

		local loadedmodulenames = {}
		local notloadedmodulenames = {}

		for name, t in LoadedClientModules do
			if t.Loaded then
				table.insert(loadedmodulenames, name)
			else
				table.insert(notloadedmodulenames, name)
			end
		end

		Logger:print("Loaded Client Modules: " .. table.concat(loadedmodulenames, ", "))
		
		if #notloadedmodulenames > 0 then
			Logger:print("Not Loaded Client Modules: " .. table.concat(notloadedmodulenames, ", "))
		end
	end)
end

function ServiceRegistry:Require(name: string)
	local info = LoadedServerModules[name] or LoadedClientModules[name]

	if not info then
		Logger:warn(("Module '%s' not registered or not accessible in this environment!"):format(name))
		return
	end

	local env = info.Env
	if env ~= "Server" and env ~= "Client" then
		env = "Shared"
	end

	if env == "Server" and RunService:IsClient() then
		Logger:warn(("Cannot require server module '%s' on client!"):format(name))
		return
	elseif env == "Client" and RunService:IsServer() then
		Logger:warn(("Cannot require client module '%s' on server!"):format(name))
		return
	end

	return info.Module
end

return table.freeze(ServiceRegistry)
